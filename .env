# SnapCut AI — Environment Configuration
# Copy this file to .env.local and fill in your values.

# Supabase Configuration
# VITE_SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# n8n Webhook Configuration
# This is the endpoint where images are sent for background removal
VITE_N8N_WEBHOOK_URL=https://shreyash111.app.n8n.cloud/webhook-test/remove-background

# Razorpay Configuration
# Get your Test Key ID from Razorpay Dashboard -> Settings -> API Keys
# It should look like rzp_test_xxxxxxxxxxxxxx
VITE_RAZORPAY_KEY_ID=rzp_test_SkNkPpMH31QTuH

# Cloudinary Configuration (Optional - for direct browser uploads)
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_UPLOAD_PRESET=
