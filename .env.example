# SnapCut AI — Environment template
# Copy to .env.local and fill in. The frontend reads VITE_* vars at build time.

# Supabase (self-hosted)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# n8n webhook that handles upload → Cloudinary → AI → response
VITE_N8N_WEBHOOK_URL=

# Cloudinary (only if you upload directly from the browser via signed uploads)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Razorpay (only the public key on the frontend; secret stays in n8n)
VITE_RAZORPAY_KEY_ID=
